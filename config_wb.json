{
	"control":true,
	"scheduler_threads":4,
	"interface":
	[
		{
			"type":"host",
			"id":"host",
			"name":"Host",
			"scan":10
		},
		{
			"type":"sht3x",
			"id":"sht31_45",
			"name":"sht31_45",
			"scan":1,
			"i2c_dev":"/dev/i2c-1",
			"i2c_id":69
		},
		{
			"type":"sht3x",
			"id":"sht31_44",
			"name":"sht31",
			"scan":1,
			"i2c_dev":"/dev/i2c-1",
			"i2c_id":68
		},
		{
			"type":"pi_gpio",
			"id":"gpio",
			"name":"gpio",
			"scan":1,
			"gpio":
			{
				"25":
				{
					"id":"r1",
					"name":"relais 1",
					"default":0,
					"mode":"output",
					"pull":"off"
				},
				"24":
				{
					"id":"r2",
					"name":"relais 2",
					"default":0,
					"mode":"output",
					"pull":"off"
				},
				"23":
				{
					"id":"r3",
					"name":"relais 3",
					"default":0,
					"mode":"output",
					"pull":"off"
				},
				"15":
				{
					"id":"ssr",
					"name":"solid state relais",
					"default":0,
					"mode":"output",
					"pull":"off"
				}
			}
		}
	],
	"webin":
	[
		{
			"id":"temp_sp",
			"name":"Temperature setpoint",
			"unit":"degC",
			"decimals":2
		},
		{
			"id":"rh_sp",
			"name":"Relative humidity setpoint",
			"unit":"%",
			"decimals":2
		}
	],
	"logic":
	[
		{
			"type":"compare",
			"id":"compare_temp",
			"name":"Compare Temperature",
			"in":"sht31_44_temp",
			"in2":"sht31_45_temp"
		},
		{
			"type":"compare",
			"id":"compare_rh",
			"in":"sht31_44_rh",
			"in2":"sht31_45_rh"
		},
		{
			"type":"compare",
			"id":"compare_abs_humidity",
			"in":"sht31_44_ah",
			"in2":"sht31_45_ah"
		}
	],
	"out":
	{
		"gpio_t22":
		{
			"expr":"1*x- 50 + c * p",
			"var":
			{
				"a":1,
				"x":"host_cpu_temperature",
				"c":3,
				"p":"gpio_t22"
			},
			"default":1
		}
	},
	"webgui":
	{
		"def_w":760,
		"def_h":260
	}
	
	
}
